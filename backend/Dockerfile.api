# Backend API tier image. Thin & stateless: publishes jobs to the queue,
# exposes SSE, relays events. Does no agent work itself.
FROM node:20-slim

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install --omit=dev && npm install tsx typescript

COPY tsconfig.json ./
COPY src ./src

ENV NODE_ENV=production
EXPOSE 3000

CMD ["npx", "tsx", "src/api/server.ts"]
