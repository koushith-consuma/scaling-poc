# Copy to .env for local runs. docker-compose sets these per-service.

# RabbitMQ (jobs IN)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_MGMT_URL=http://guest:guest@localhost:15672
RUN_QUEUE=agent-run-queue

# Mongo (source of truth)
MONGO_URL=mongodb://localhost:27017
MONGO_DB=viper

# Redis (events OUT, fire-and-forget)
REDIS_URL=redis://localhost:6379

# Web tier
WEB_PORT=3000

# Worker / loop tuning
WORKER_PREFETCH=1
POOL_SIZE=3
SANDBOX_IMAGE=alpine:3.20

# Mock model / tool tuning
MODEL_MIN_DELAY_MS=500
MODEL_MAX_DELAY_MS=3000
MOCK_SEED=
